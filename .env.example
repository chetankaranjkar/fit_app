# Copy to `.env` for tools that load it (optional). ASP.NET reads env vars automatically if you export them before `dotnet run`.
#
# Prefer User Secrets so nothing sensitive lives in repo files:
#   dotnet user-secrets set "Redis:ConnectionString" "localhost:6379" --project src/GymManagement.API/GymManagement.API.csproj

# Enables Redis replay protection + QR rate limiting (omit or leave blank to disable in dev).
Redis__ConnectionString=

# Typical local Redis (Docker: docker run -d -p 6379:6379 redis:7-alpine)
# Redis__ConnectionString=localhost:6379

# Azure Cache for Redis-style (example shape only — use your hostname and key from the portal).
# Redis__ConnectionString=my-cache.redis.cache.windows.net:6380,password=PASTE_KEY_HERE,ssl=True,abortConnect=False
