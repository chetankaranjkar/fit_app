{
  "UseSqlite": false,
  "Database": {
    "AutoMigrate": true
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "GymManagement",
    "Audience": "GymManagement",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "DoorDevice": {
    "Enabled": false
  },
  "Notifications": {
    "EnableScheduledReminders": false
  }
}
