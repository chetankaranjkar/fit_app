# Copy to deploy/.env on the VPS and fill in real values.
# NEVER commit deploy/.env to git.

# --- Required ---
DOMAIN=app.example.com
DEPLOY_MODE=production
CORS_ORIGIN_0=https://app.example.com
CORS_ORIGIN_1=http://app.example.com
MSSQL_SA_PASSWORD=ChangeMe_Use_A_Strong_Password_16plus!
JWT_SECRET_KEY=ChangeMe_Use_At_Least_32_Random_Characters_Long!

# --- Database ---
MSSQL_DATABASE=GymManagementDb
MSSQL_MEMORY_LIMIT_MB=1536
SQLSERVER_MEMORY_LIMIT=1800m
DATABASE_AUTO_MIGRATE=true

# --- JWT (optional overrides) ---
JWT_ISSUER=GymManagement
JWT_AUDIENCE=GymManagement

# --- Host ports (bound to 127.0.0.1 only — Nginx proxies these) ---
API_HOST_PORT=5104
FRONTEND_HOST_PORT=8080
EXERCISE_API_HOST_PORT=4300

# --- Redis (in-container; leave defaults on small VPS) ---
REDIS_MAXMEMORY=128mb

# --- Memory limits (Docker mem_limit) ---
API_MEMORY_LIMIT=512m

# --- SSL paths on host (Certbot default) ---
SSL_CERT_PATH=/etc/letsencrypt/live/app.example.com

# --- Optional integrations ---
DOOR_DEVICE_ENABLED=false
DOOR_DEVICE_URL=
NOTIFICATIONS_EMAIL_WEBHOOK=
NOTIFICATIONS_WHATSAPP_WEBHOOK=

# Exercise / AI API (optional — leave blank to disable AI provider calls)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PROVIDER=auto
HF_API_KEY=
HF_MODEL=

# Certbot email for Let's Encrypt expiry notices
CERTBOT_EMAIL=admin@example.com

# --- Firebase OTP (customer-owned project; customer pays Google Blaze/SMS) ---
# See docs/FIREBASE_OTP_PRODUCTION.md for full setup.
FIREBASE_ENABLED=false
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
# Place service account JSON at: deploy/secrets/firebase-service-account.json (never commit)
