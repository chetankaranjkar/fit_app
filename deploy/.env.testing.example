# Testing / no domain — copy to deploy/.env on your VPS
# Access the app at:  http://YOUR_VPS_PUBLIC_IP

DEPLOY_MODE=testing

# Your VPS public IP (from Hostinger panel). Used for CORS only; app uses relative /api paths.
VPS_IP=187.127.169.135

# --- Required secrets (same as production) ---
MSSQL_SA_PASSWORD=ChangeMe_Use_A_Strong_Password_16plus!
JWT_SECRET_KEY=ChangeMe_Use_At_Least_32_Random_Characters_Long!

# --- Optional: lower RAM on small test VPS ---
MSSQL_MEMORY_LIMIT_MB=1024
SQLSERVER_MEMORY_LIMIT=1200m
API_MEMORY_LIMIT=384m

MSSQL_DATABASE=GymManagementDb
# Host port for SQL (same as: docker run -p 1433:1433)
SQLSERVER_PUBLISH_PORT=1433
DATABASE_AUTO_MIGRATE=true
DATABASE_SEED_DEFAULTS=true

JWT_ISSUER=GymManagement
JWT_AUDIENCE=GymManagement

# Not used in testing mode (leave blank)
DOMAIN=
CERTBOT_EMAIL=

# Optional AI keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
