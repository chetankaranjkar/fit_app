# UAT — copy to deploy/.env.uat on the VPS (never commit deploy/.env.uat).
# App URL: https://uat.tigerfitness.tech/dashboard
#
# DNS: A record  uat.tigerfitness.tech  →  same VPS public IP as production

DEPLOY_MODE=production
DOMAIN=uat.tigerfitness.tech

# CORS (API must allow the browser origin)
CORS_ORIGIN_0=https://uat.tigerfitness.tech
CORS_ORIGIN_1=http://uat.tigerfitness.tech

# Host ports (127.0.0.1 only — production uses 8080 / 5104 / 4300 / 1433)
FRONTEND_HOST_PORT=8081
API_HOST_PORT=5105
EXERCISE_API_HOST_PORT=4301
SQLSERVER_PUBLISH_PORT=1434

# --- Required secrets (use UAT-specific values; do not reuse production JWT) ---
MSSQL_SA_PASSWORD=ChangeMe_UAT_Strong_Password_16plus!
JWT_SECRET_KEY=ChangeMe_UAT_At_Least_32_Random_Characters_Long!
CERTBOT_EMAIL=you@tigerfitness.in

# --- Database (isolated from production volume) ---
MSSQL_DATABASE=GymManagementDb_UAT
MSSQL_MEMORY_LIMIT_MB=1024
SQLSERVER_MEMORY_LIMIT=1200m
DATABASE_AUTO_MIGRATE=true
DATABASE_SEED_DEFAULTS=true

JWT_ISSUER=GymManagement
JWT_AUDIENCE=GymManagement

API_MEMORY_LIMIT=384m
REDIS_MAXMEMORY=96mb

SSL_CERT_PATH=/etc/letsencrypt/live/uat.tigerfitness.tech

# Optional: commit SHA shown in /api/deploy-info
GIT_COMMIT_SHA=

# Firebase OTP — add uat.tigerfitness.tech in Firebase Console (Authorized domains)
FIREBASE_ENABLED=false
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
