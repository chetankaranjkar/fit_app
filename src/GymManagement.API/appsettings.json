{
  "UseSqlite": false,
  "SqlServerDataPath": null,
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=GymManagementDb;Trusted_Connection=true;MultipleActiveResultSets=true;TrustServerCertificate=true"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyThatShouldBeAtLeast32CharactersLongForSecurity!",
    "Issuer": "GymManagement",
    "Audience": "GymManagement",
    "AccessTokenMinutes": 43200,
    "RefreshTokenDays": 90,
    "MaxPermissionClaims": 128
  },
  "DeviceSecurity": {
    "MaxActiveDevices": 3,
    "EnableSessionValidation": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DoorDevice": {
    "Esp32BaseUrl": "",
    "Enabled": false,
    "TimeoutSeconds": 5,
    "AllowOverrideBaseUrl": false
  },
  "Notifications": {
    "EmailWebhookUrl": "",
    "WhatsAppWebhookUrl": "",
    "MaxRetries": 3,
    "TimeoutSeconds": 15,
    "EnableScheduledReminders": false,
    "ReminderIntervalHours": 24,
    "MembershipExpiryReminderDays": 7
  },
  "AllowedHosts": "*"
}
